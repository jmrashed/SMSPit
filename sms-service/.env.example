PORT=3000
CORS_ORIGIN=*

DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=smspit
DB_USERNAME=smspit
DB_PASSWORD=smspit
DB_POOL_SIZE=10

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

AUTH_SERVICE_URL=http://localhost:8000

# ai-service is optional infra -- OTP detection degrades to "not
# detected" (never blocks capture) if this is unset or unreachable.
AI_SERVICE_URL=http://localhost:8001

# OpenTelemetry (Day 83) -- tracing is disabled entirely if unset. Point
# at an OTLP/HTTP collector (e.g. Jaeger's all-in-one, see docker-compose.yml).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
