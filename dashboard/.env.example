# Points directly at sms-service until gateway exists (Day 37+), at
# which point this should switch to the gateway's port.
VITE_API_BASE_URL=http://localhost:3000

# sms-service requires an API key as of Day 35. Generate one via
# POST /api/api-keys on auth-service and paste it here, or use the
# /api-keys page (Day 47) once you have at least one key to get in.
VITE_API_KEY=

# Called directly for the API key management page (Day 47) -- not yet
# routed through VITE_API_BASE_URL/the gateway.
VITE_AUTH_SERVICE_URL=http://localhost:8000
