{
    "name": "smspit/sdk",
    "description": "PHP client for SMSPit's REST API (send, list, replay messages).",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SMSPit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SMSPit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
